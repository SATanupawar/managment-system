# MongoDB Atlas connection string
# Get this from: Atlas → Connect → Drivers → copy full string
# MUST include username AND password:
# mongodb+srv://DB_USERNAME:DB_PASSWORD@cluster0.xxxxx.mongodb.net/hr_recruitment
# If password has special characters, URL-encode them (@ → %40, # → %23)
MONGODB_URI=mongodb+srv://YOUR_DB_USERNAME:YOUR_DB_PASSWORD@cluster0.mavcand.mongodb.net/hr_recruitment?retryWrites=true&w=majority&appName=Cluster0

# JWT Secret - use any random string (for password encryption)
JWT_SECRET=your-super-secret-key-change-this

# Cloudinary - cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# HR Login Credentials - HR username and password
HR_USERNAME=hr@yourcompany.com
HR_PASSWORD=YourStrongPassword123
